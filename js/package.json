{
  "name": "open-dealias-js",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/open_dealias.js",
  "types": "./dist/open_dealias.d.ts",
  "exports": {
    ".": {
      "import": "./dist/open_dealias.js",
      "types": "./dist/open_dealias.d.ts"
    },
    "./wasm": {
      "import": "./dist/open_dealias_wasm.js",
      "types": "./dist/open_dealias_wasm.d.ts"
    }
  },
  "files": [
    "dist",
    "pkg"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:wasm": "wasm-pack build ../rust/open_dealias_wasm --target web --out-dir ../../js/pkg --release",
    "build:all": "npm run build && npm run build:wasm",
    "test": "npm run build && node --test dist/*.test.js",
    "profile:fast": "npm run build && node --expose-gc profile_fastpath.mjs half",
    "profile:full": "npm run build && node --expose-gc profile_fastpath.mjs full",
    "profile:fragmented": "npm run build && node --expose-gc profile_fastpath.mjs fragmented"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "typescript": "^5.8.3"
  }
}
